# Spider Web Crawler - Environment Configuration
# Copy this file to .env and fill in your values

# API server port
PORT=9000

# Redis connection URL
REDIS_URL=redis://127.0.0.1:6379

# SQLite database path
DATABASE_URL=sqlite://spider.db

# Proxy configuration (optional)
# Supports HTTP and SOCKS5 proxies for anti-bot bypass
# PROXY_HOST=proxy.example.com
# PROXY_PORT=8080
# PROXY_USERNAME=
# PROXY_PASSWORD=
# PROXY_PROTOCOL=http

# Proxy mode: always | fallback | never
# always   - Route all requests through proxy
# fallback - Try direct first, use proxy only when blocked (default)
# never    - Never use proxy even if configured
PROXY_MODE=fallback

# Maximum number of concurrent worker threads
MAX_WORKERS=3

# Rust log level (trace, debug, info, warn, error)
RUST_LOG=info
